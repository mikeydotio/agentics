{
  "description": "Hook-guard — clears circuit breaker state on new sessions",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup,resume,clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
